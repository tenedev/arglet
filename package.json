{
  "name": "arglet",
  "displayName": "Arglet",
  "version": "1.1.0",
  "description": "A tiny helper that lets your CLI args lead the configuration merging process",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teneplaysofficial/arglet.git"
  },
  "homepage": "https://teneplaysofficial.github.io/arglet",
  "funding": "https://github.com/sponsors/teneplaysofficial",
  "keywords": [
    "cli",
    "args",
    "config",
    "merge",
    "argv",
    "developer-tools"
  ],
  "author": "Sriman",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky",
    "test": "pnpm type-check && vitest run --coverage",
    "type-check": "tsc --noEmit",
    "build": "tsdown",
    "release": "release-hub",
    "fix": "biome check --write",
    "lint": "biome check"
  },
  "lint-staged": {
    "*.{js,ts,json}": "biome check --write"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "4.0.18",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "release-hub": "1.0.0-beta.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
