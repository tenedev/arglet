{
  "name": "arglet",
  "displayName": "Arglet",
  "version": "1.1.0",
  "description": "A tiny helper that lets your CLI args lead the configuration merging process",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teneplaysofficial/arglet.git"
  },
  "homepage": "https://teneplaysofficial.github.io/arglet",
  "funding": "https://github.com/sponsors/teneplaysofficial",
  "keywords": [
    "cli",
    "args",
    "config",
    "merge",
    "argv",
    "developer-tools"
  ],
  "author": "Sriman",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky",
    "test": "pnpm type-check && vitest run --coverage",
    "type-check": "tsc --noEmit",
    "build": "tsdown",
    "release": "release-hub",
    "fix": "biome check --write",
    "lint": "biome check"
  },
  "lint-staged": {
    "*.{js,ts,json}": "biome check --write"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "4.0.18",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "release-hub": "1.0.0-beta.1",
    "tsdown": "0.21.8",
    "typescript": "6.0.2",
    "vitest": "^4.0.18"
  }
}
